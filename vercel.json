{
  "_deprecated": "AWS EC2 (Docker) is the primary deployment target. This config is preserved for reference only.",
  "build": {
    "pre": "rm -rf __pycache__ api/__pycache__ api/services/__pycache__",
    "env": {
      "PYTHONDONTWRITEBYTECODE": "0"
    }
  },
  "routes": [
    {
      "src": "/api/v2/(.*)",
      "dest": "/api/main.py"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/public/assets/$1"
    },
    {
      "src": "/meshes/(.*)",
      "dest": "/public/meshes/$1"
    }
  ],
  "framework": null
}
